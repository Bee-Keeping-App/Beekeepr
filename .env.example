# ─── Backend ────────────────────────────────────────────────────────────────────
# MongoDB connection strings (from MongoDB Atlas or local)
MONGO_TEST=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<test-db>
MONGO_PROD=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<prod-db>

# Set to 'true' to use MONGO_PROD, otherwise MONGO_TEST is used
USE_PROD=false

# Clerk secret key (from Clerk dashboard -> API Keys)
CLERK_SECRET_KEY=sk_test_...

# ─── Frontend (Expo) ─────────────────────────────────────────────────────────────
# Clerk publishable key (from Clerk dashboard -> API Keys)
# Must be prefixed with EXPO_PUBLIC_ to be accessible in the client bundle
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
